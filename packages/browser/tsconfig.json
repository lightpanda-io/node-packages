{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "esModuleInterop": true,
    "target": "es6",
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "dist",
    "declaration": true,
    "composite": true,
    "declarationMap": true,
    "paths": {
      "lightpanda/*": ["./src/*"],
      "scripts/*": ["./scripts/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules, .yarn", "dist"]
}
